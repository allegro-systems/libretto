    "landing.about.description": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Libretto ist eine Schreibplattform, auf der Ideen ihr Publikum finden. Lesen, schreiben und vernetzen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Libretto is a writing platform where ideas find their audience. Read, write, and connect."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Libretto es una plataforma de escritura donde las ideas encuentran su audiencia. Lee, escribe y conecta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Libretto est une plateforme d'écriture où les idées trouvent leur public. Lisez, écrivez et connectez."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Libretto è una piattaforma di scrittura dove le idee trovano il loro pubblico. Leggi, scrivi e connettiti."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Libretto — это платформа для авторов, где идеи находят свою аудиторию. Читайте, пишите и общайтесь."
          }
        }
      }
    },
